{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ESNext",

    "rootDir": "./src",
    "outDir": "./dist",

    "types": ["node"],

    "sourceMap": true,

    "strict": true,

    "verbatimModuleSyntax": false,

    "isolatedModules": true,
    "moduleDetection": "force",

    "skipLibCheck": true,

    "esModuleInterop": true
  },

  "include": ["src"]
}